{
  "name": "fincontrol-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:web": "npm --workspace frontend run start",
    "dev:api": "npm --workspace backend run dev",
    "build:web": "npm --workspace frontend run build",
    "build:api": "npm --workspace backend run build",
    "build": "npm run build:web && npm run build:api",
    "test:web": "npm --workspace frontend run test",
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}